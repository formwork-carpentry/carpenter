{
  "name": "@carpentry/carpenter",
  "version": "1.0.0",
  "description": "Carpenter — the full-stack TypeScript framework",
  "workspaces": [
    "cli",
    "create-carpenter-app"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@carpentry/formworks": "^1.0.0"
  },
  "peerDependencies": {
    "@carpentry/db-sqlite": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@carpentry/db-sqlite": { "optional": true }
  }
}
